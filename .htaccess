# BEGIN Rewrite

<IfModule mod_rewrite.c>

RewriteEngine On

<FilesMatch "^(config\.php|composer\.(json|lock)|package\.json|\.env|.*\.md)$">
	Require all denied
</FilesMatch>

RewriteRule ^(controllers|libs|vendor|views)/ - [F,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^$ index.php [L,QSA]

RewriteRule ^([^/]+)/?$ index.php?page=$1 [L,QSA]

</IfModule>

ErrorDocument 404 /index.php?page=404
